---
---

<section id="contact" style="padding: 8rem 1.5rem; background: #ffffff; position: relative; overflow: hidden;">
  <div class="orb" style="width: 500px; height: 500px; bottom: -10%; right: -8%; background: radial-gradient(circle, rgba(109,40,217,0.08) 0%, transparent 70%);"></div>
  <div class="bg-dots" style="position: absolute; inset: 0; z-index: 0; opacity: 0.5;"></div>

  <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
    <div class="reveal" style="text-align: center; margin-bottom: 4rem;">
      <span class="section-label" style="display: inline-flex; margin-bottom: 1.25rem;">비즈니스 문의</span>
      <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; margin-top: 1.25rem; color: #0f172a;">
        함께 만드는 <span class="gradient-text">AI의 미래</span>
      </h2>
      <p style="font-size: 1.05rem; color: #64748b; margin-top: 1rem; max-width: 440px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        SaaS 사전 신청, 강의 문의, 협업 제안—모두 환영합니다.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
      <!-- Contact Form -->
      <div class="card reveal" style="border-radius: 1.75rem; padding: 2.5rem; box-shadow: 0 8px 32px rgba(0,0,0,0.08);">
        <h3 style="font-size: 1.3rem; font-weight: 800; color: #0f172a; margin-bottom: 0.375rem; letter-spacing: -0.02em;">문의 보내기</h3>
        <p style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 2rem;">빠른 시일 내에 답변 드리겠습니다.</p>

        <form id="contact-form" style="display: flex; flex-direction: column; gap: 1rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            <div>
              <label for="name" style="display: block; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.5rem;">이름 *</label>
              <input type="text" id="name" name="name" placeholder="홍길동" required class="form-input" />
            </div>
            <div>
              <label for="email" style="display: block; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.5rem;">이메일 *</label>
              <input type="email" id="email" name="email" placeholder="you@company.com" required class="form-input" />
            </div>
          </div>

          <div>
            <label for="inquiry-type" style="display: block; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.5rem;">문의 유형 *</label>
            <select id="inquiry-type" name="type" required class="form-input">
              <option value="" disabled selected>선택하세요</option>
              <option value="saas">AI SaaS 사전 신청</option>
              <option value="lecture">강의 / DX 컨설팅</option>
              <option value="partnership">협업 제안</option>
              <option value="other">기타 문의</option>
            </select>
          </div>

          <div>
            <label for="company" style="display: block; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.5rem;">회사/기관명</label>
            <input type="text" id="company" name="company" placeholder="(주)원그라운드" class="form-input" />
          </div>

          <div>
            <label for="message" style="display: block; font-size: 0.8rem; font-weight: 700; color: #475569; margin-bottom: 0.5rem;">메시지 *</label>
            <textarea id="message" name="message" rows="4" placeholder="문의 내용을 자세히 적어주세요..." required class="form-input" style="resize: vertical; min-height: 100px;"></textarea>
          </div>

          <button type="submit" class="btn-primary" style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-top: 0.5rem;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            문의 전송하기
          </button>
        </form>
      </div>

      <!-- Right column -->
      <div style="display: flex; flex-direction: column; gap: 1.125rem;">
        {[
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>`, color: '#4f46e5', bg: 'rgba(79,70,229,0.07)', border: 'rgba(79,70,229,0.14)', title: 'AI SaaS 사전 신청', desc: '얼리어답터 혜택과 함께 무인 공간 자동화를 가장 먼저 경험하세요.' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`, color: '#d97706', bg: 'rgba(217,119,6,0.07)', border: 'rgba(217,119,6,0.14)', title: '강의 & DX 컨설팅', desc: '기업, 공공기관, 교육기관 맞춤 AI 실무 교육 프로그램을 제안드립니다.' },
          { icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>`, color: '#059669', bg: 'rgba(5,150,105,0.07)', border: 'rgba(5,150,105,0.14)', title: '협업 파트너십', desc: '공간 브랜드, 기술 스타트업, 투자사와의 협업을 환영합니다.' },
        ].map((info, i) => (
          <div
            class={`card card-hover reveal reveal-delay-${i + 1}`}
            style="border-radius: 1.25rem; padding: 1.5rem; display: flex; gap: 1rem; align-items: flex-start;"
          >
            <div style={`width: 46px; height: 46px; background: ${info.bg}; border: 1px solid ${info.border}; border-radius: 13px; display: flex; align-items: center; justify-content: center; color: ${info.color}; flex-shrink: 0;`}>
              <Fragment set:html={info.icon} />
            </div>
            <div>
              <h4 style="font-size: 0.95rem; font-weight: 800; color: #0f172a; margin-bottom: 0.25rem;">{info.title}</h4>
              <p style="font-size: 0.825rem; color: #64748b; line-height: 1.65;">{info.desc}</p>
            </div>
          </div>
        ))}

        <!-- Newsletter -->
        <div
          class="reveal reveal-delay-4"
          style="border-radius: 1.25rem; padding: 1.75rem; background: linear-gradient(135deg, #4f46e5, #7c3aed); color: white;"
        >
          <h4 style="font-size: 1rem; font-weight: 800; margin-bottom: 0.375rem;">📬 뉴스레터 구독</h4>
          <p style="font-size: 0.825rem; opacity: 0.8; margin-bottom: 1.125rem;">AI 공간 경영 인사이트를 격주로 받아보세요.</p>
          <form id="newsletter-form" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <input
              type="email"
              id="newsletter-email"
              name="email"
              placeholder="이메일 주소 입력"
              required
              style="flex: 1; min-width: 160px; background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.25); border-radius: 0.625rem; padding: 0.75rem 1rem; color: white; font-size: 0.875rem; font-family: inherit; outline: none; transition: background 0.2s ease;"
            />
            <button type="submit" style="background: white; color: #4f46e5; border: none; border-radius: 0.625rem; padding: 0.75rem 1.25rem; font-weight: 700; font-size: 0.875rem; cursor: pointer; font-family: inherit; transition: all 0.2s ease;">
              구독
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    section#contact div[style*="grid-template-columns: 1fr 1fr"] { grid-template-columns: 1fr !important; }
  }
  input[placeholder]::placeholder { color: rgba(255,255,255,0.5); }
</style>

<script>
  document.getElementById('contact-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = e.target?.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (btn) {
      btn.textContent = '✓ 전송 완료!';
      btn.style.background = 'linear-gradient(135deg, #059669, #10b981)';
      setTimeout(() => {
        btn.innerHTML = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg> 문의 전송하기`;
        btn.style.background = '';
      }, 3000);
    }
  });
  document.getElementById('newsletter-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = e.target?.querySelector('button[type="submit"]') as HTMLButtonElement;
    const input = document.getElementById('newsletter-email') as HTMLInputElement;
    if (btn && input) { btn.textContent = '✓ 구독!'; input.value = ''; setTimeout(() => { btn.textContent = '구독'; }, 3000); }
  });
</script>
