---
---

<section
  id="hero"
  style="
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    padding: 9rem 1.5rem 5rem;
    background: #ffffff;
  "
>
  <!-- Dot background -->
  <div class="bg-dots" style="position: absolute; inset: 0; z-index: 0;"></div>

  <!-- Soft color orbs -->
  <div class="orb" style="width: 600px; height: 600px; top: -15%; left: -10%; background: radial-gradient(circle, rgba(109,40,217,0.12) 0%, transparent 70%);"></div>
  <div class="orb" style="width: 500px; height: 500px; bottom: -10%; right: -5%; background: radial-gradient(circle, rgba(37,99,235,0.1) 0%, transparent 70%);"></div>
  <div class="orb" style="width: 300px; height: 300px; top: 30%; right: 20%; background: radial-gradient(circle, rgba(139,92,246,0.08) 0%, transparent 70%); animation: float 7s ease-in-out infinite;"></div>

  <!-- Content -->
  <div style="max-width: 860px; margin: 0 auto; text-align: center; position: relative; z-index: 2;">

    <!-- Badge -->
    <div class="reveal" style="margin-bottom: 1.75rem;">
      <span class="section-label">
        <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor"><circle cx="4" cy="4" r="4"/></svg>
        AI 비즈니스 아키텍트
      </span>
    </div>

    <!-- Headline -->
    <h1
      class="reveal reveal-delay-1"
      style="
        font-size: clamp(2.75rem, 7.5vw, 5.25rem);
        font-weight: 900;
        line-height: 1.08;
        letter-spacing: -0.04em;
        color: #0f172a;
        margin-bottom: 1.5rem;
      "
    >
      현장의 문제를<br />
      <span class="gradient-text">AI로 해결합니다</span>
    </h1>

    <!-- Sub copy -->
    <p
      class="reveal reveal-delay-2"
      style="
        font-size: clamp(1rem, 2.5vw, 1.2rem);
        color: #64748b;
        line-height: 1.75;
        max-width: 580px;
        margin: 0 auto 2.75rem;
        font-weight: 400;
      "
    >
      공간 경영에서 SaaS 솔루션까지.<br />
      무인 공간 운영자를 위한 AI 자동화 플랫폼,
      <strong style="color: #6d28d9; font-weight: 700;">원그라운드</strong>가
      당신의 비즈니스를 혁신합니다.
    </p>

    <!-- CTAs -->
    <div class="reveal reveal-delay-3" style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
      <a href="#contact" class="btn-primary">
        🚀 &nbsp;AI SaaS 사전 신청
      </a>
      <a href="#cases" class="btn-secondary">
        케이스 스터디 보기
      </a>
    </div>

    <!-- Stats row -->
    <div
      class="reveal reveal-delay-4"
      style="
        margin-top: 4.5rem;
        display: inline-flex;
        gap: 0;
        background: white;
        border: 1px solid rgba(0,0,0,0.08);
        border-radius: 1.25rem;
        box-shadow: 0 4px 24px rgba(0,0,0,0.07);
        overflow: hidden;
        flex-wrap: wrap;
      "
    >
      {[
        { num: '80', suffix: '%+', label: '예약 자동화율', icon: '⚡' },
        { num: '40', suffix: '%↓', label: '운영 비용 절감', icon: '💰' },
        { num: '500', suffix: '명+', label: '강의 수강생', icon: '🎓' },
      ].map((item, i) => (
        <div style={`text-align: center; padding: 1.5rem 2.25rem; ${i < 2 ? 'border-right: 1px solid rgba(0,0,0,0.07);' : ''}`}>
          <div style="font-size: 0.75rem; color: #94a3b8; margin-bottom: 0.35rem;">{item.icon}</div>
          <div style="font-size: 1.875rem; font-weight: 900; color: #0f172a; letter-spacing: -0.03em; line-height: 1;">
            <span data-count={item.num.replace(/[^0-9]/g,'')} data-suffix={item.num.replace(/[0-9]/g,'') + item.suffix}>
              {item.num}{item.suffix}
            </span>
          </div>
          <div style="font-size: 0.78rem; color: #94a3b8; margin-top: 0.35rem; font-weight: 500;">{item.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div style="position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column; align-items: center; gap: 0.5rem; z-index:2;">
    <span style="font-size: 0.68rem; color: #cbd5e1; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 600;">Scroll</span>
    <div style="width: 1px; height: 36px; background: linear-gradient(to bottom, #6d28d9, transparent);"></div>
  </div>
</section>
