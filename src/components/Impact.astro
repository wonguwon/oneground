---

<section id="impact" style="padding: 8rem 1.5rem; background: #f8f9fc; position: relative; overflow: hidden;">
  <div class="bg-dots" style="position: absolute; inset: 0; z-index: 0; opacity: 0.6;"></div>
  
  <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
    <div class="reveal" style="text-align: center; margin-bottom: 4.5rem;">
      <span class="section-label" style="display: inline-flex; margin-bottom: 1.25rem;">신뢰와 영향력</span>
      <h2 style="font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; margin-top: 1.25rem; color: #0f172a;">
        검증된 전문성, <span class="gradient-text">현장의 증명</span>
      </h2>
      <p style="font-size: 1.1rem; color: #64748b; margin-top: 1rem; max-width: 520px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        운영자들의 생생한 후기부터 주요 매체 출연 정보까지,<br />원그라운드의 가치는 현장에서 만들어집니다.
      </p>
    </div>

    <!-- Impact Cards Grid -->
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
      {impacts.map((item, i) => (
        <article 
          class={`card card-hover reveal reveal-delay-${(i % 3) + 1}`}
          style="background: white; border-radius: 1.5rem; padding: 2rem; display: flex; flex-direction: column; justify-content: space-between;"
        >
          <div>
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
              <span style={`font-size: 0.7rem; font-weight: 800; color: ${item.badgeColor}; background: ${item.badgeBg}; padding: 0.25rem 0.75rem; border-radius: 9999px; text-transform: uppercase; letter-spacing: 0.05em;`}>
                {item.type}
              </span>
              <div style={`color: ${item.badgeColor}; opacity: 0.8;`}>
                <Fragment set:html={item.icon} />
              </div>
            </div>
            
            <h3 style="font-size: 1.2rem; font-weight: 800; color: #0f172a; margin-bottom: 0.75rem; letter-spacing: -0.02em;">
              {item.title}
            </h3>
            <p style="font-size: 0.95rem; color: #475569; line-height: 1.7; margin-bottom: 1.5rem;">
              "{item.content}"
            </p>
          </div>

          <div style="padding-top: 1.25rem; border-top: 1px solid rgba(0,0,0,0.06); display: flex; align-items: center; gap: 0.5rem;">
            <div style={`width: 8px; height: 8px; background: ${item.badgeColor}; border-radius: 50%;`}></div>
            <span style="font-size: 0.85rem; font-weight: 700; color: #1e293b;">{item.footer}</span>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
