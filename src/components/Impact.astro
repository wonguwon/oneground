---
const career = [
  { year: '2015', title: '개발 시작', desc: '풀스택 개발자로 커리어 시작', color: '#94a3b8' },
  { year: '2018', title: 'AI/ML 전환', desc: '머신러닝·딥러닝 전문화', color: '#6d28d9' },
  { year: '2021', title: '기업 강의 시작', desc: '기업 DX 및 AI 실무 강의 진행', color: '#4f46e5' },
  { year: '2022', title: 'KDT 부트캠프', desc: '국비지원 AI 교육 과정 리드', color: '#0891b2' },
  { year: '2023', title: '파티룸 운영', desc: '게임파티룸 밤샘 직접 창업·운영', color: '#059669' },
  { year: '2024', title: '스페이스데스크', desc: '밤샘 운영 데이터 기반 SaaS 개발', color: '#d97706' },
];

const lectures = [
  { org: '대기업 임원 특강', type: '기업 DX', count: '임원진 대상', color: '#4f46e5', bg: 'rgba(79,70,229,0.07)', border: 'rgba(79,70,229,0.14)' },
  { org: 'KDT AI 부트캠프', type: '국비 교육', count: '50명+ 수료', color: '#059669', bg: 'rgba(5,150,105,0.07)', border: 'rgba(5,150,105,0.14)' },
  { org: '공공기관 AI 강의', type: '공공 교육', count: '다수 기관', color: '#d97706', bg: 'rgba(217,119,6,0.07)', border: 'rgba(217,119,6,0.14)' },
  { org: '스타트업 DX 컨설팅', type: '컨설팅', count: '다수 프로젝트', color: '#0891b2', bg: 'rgba(8,145,178,0.07)', border: 'rgba(8,145,178,0.14)' },
];
---

<section id="trust" style="padding: 8rem 1.5rem; background: #f8f9fc; position: relative; overflow: hidden;">
  <div class="bg-dots" style="position: absolute; inset: 0; z-index: 0; opacity: 0.6;"></div>

  <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
    <div class="reveal" style="text-align: center; margin-bottom: 4.5rem;">
      <span class="section-label" style="display: inline-flex; margin-bottom: 1.25rem;">신뢰도</span>
      <h2 style="font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; margin-top: 1.25rem; color: #0f172a;">
        직접 운영하며 검증했습니다
      </h2>
      <p style="font-size: 1.1rem; color: #64748b; margin-top: 1rem; max-width: 540px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        기술과 현장, 교육을 모두 아는 사람이 만든 솔루션입니다.<br />10년 개발 경력 위에 직접 파티룸을 운영하며 쌓은 실전 노하우.
      </p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-bottom: 2rem;">

      <!-- 파티룸 운영 스토리 -->
      <div class="card reveal" style="border-radius: 1.75rem; overflow: hidden;">
        <div style="padding: 2.25rem; background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); position: relative; overflow: hidden;">
          <div style="position: absolute; top: -40px; right: -40px; width: 200px; height: 200px; background: radial-gradient(circle, rgba(109,40,217,0.35) 0%, transparent 70%); pointer-events: none;"></div>
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">🎮</div>
            <span style="font-size: 0.72rem; font-weight: 700; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 0.1em;">오프라인 운영 Lab</span>
            <h3 style="font-size: 1.5rem; font-weight: 900; color: white; margin-top: 0.4rem; letter-spacing: -0.03em;">게임파티룸 밤샘</h3>
            <p style="font-size: 0.875rem; color: rgba(255,255,255,0.6); margin-top: 0.25rem;">스페이스데스크의 첫 번째 테스트베드</p>
          </div>
        </div>
        <div style="padding: 2rem; background: white;">
          <p style="font-size: 0.95rem; color: #475569; line-height: 1.8; margin-bottom: 1.5rem;">
            직접 파티룸을 운영하며 고객 문의·예약·노쇼 문제를 직접 체감했습니다. 스페이스데스크를 자사 파티룸에 먼저 적용해 실제 운영 데이터를 기반으로 제품을 지속 개선하고 있습니다.
          </p>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
            {[
              { num: '85', suffix: '%+', label: '문의 자동화율', color: '#4f46e5' },
              { num: '0', suffix: '건', label: '수동 문자 발송', color: '#059669' },
            ].map(s => (
              <div style="text-align: center; padding: 1rem; background: #f8f9fc; border-radius: 0.875rem;">
                <div style={`font-size: 1.75rem; font-weight: 900; color: ${s.color}; letter-spacing: -0.03em; line-height: 1;`}>
                  <span data-count={s.num} data-suffix={s.suffix}>{s.num}{s.suffix}</span>
                </div>
                <div style="font-size: 0.75rem; color: #94a3b8; margin-top: 0.3rem; font-weight: 500;">{s.label}</div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- 10년 경력 타임라인 -->
      <div class="card reveal reveal-delay-1" style="border-radius: 1.75rem; padding: 2.25rem; background: white;">
        <div style="margin-bottom: 1.75rem;">
          <span style="font-size: 0.72rem; font-weight: 700; color: #6d28d9; background: rgba(109,40,217,0.08); border: 1px solid rgba(109,40,217,0.15); padding: 0.2rem 0.75rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;">10년 개발 경력</span>
          <h3 style="font-size: 1.35rem; font-weight: 900; color: #0f172a; margin-top: 0.5rem; letter-spacing: -0.03em;">👨‍💻 풀스택 AI 개발자</h3>
          <p style="font-size: 0.875rem; color: #64748b; margin-top: 0.25rem;">기업 DX 강의 · KDT 부트캠프 · AI 실무 솔루션 개발</p>
        </div>

        <!-- Timeline -->
        <div style="display: flex; flex-direction: column; gap: 0;">
          {career.map((item, i) => (
            <div style={`display: flex; gap: 1rem; align-items: flex-start; ${i < career.length - 1 ? 'padding-bottom: 1.125rem;' : ''}`}>
              <div style="display: flex; flex-direction: column; align-items: center; flex-shrink: 0; padding-top: 0.2rem;">
                <div style={`width: 10px; height: 10px; border-radius: 50%; background: ${item.color}; flex-shrink: 0;`}></div>
                {i < career.length - 1 && <div style={`width: 2px; flex: 1; background: linear-gradient(to bottom, ${item.color}40, ${career[i+1].color}40); min-height: 24px; margin-top: 4px;`}></div>}
              </div>
              <div style="padding-bottom: 0.125rem;">
                <div style="display: flex; align-items: center; gap: 0.625rem; margin-bottom: 0.1rem;">
                  <span style={`font-size: 0.7rem; font-weight: 800; color: ${item.color}; letter-spacing: 0.06em;`}>{item.year}</span>
                  <span style="font-size: 0.875rem; font-weight: 700; color: #0f172a;">{item.title}</span>
                </div>
                <p style="font-size: 0.8rem; color: #64748b;">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- 강의 이력 -->
    <div class="card reveal" style="border-radius: 1.75rem; padding: 2.25rem; background: white;">
      <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.75rem; flex-wrap: wrap; gap: 1rem;">
        <div>
          <span style="font-size: 0.72rem; font-weight: 700; color: #d97706; background: rgba(217,119,6,0.08); border: 1px solid rgba(217,119,6,0.18); padding: 0.2rem 0.75rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;">강의 이력</span>
          <h3 style="font-size: 1.35rem; font-weight: 900; color: #0f172a; margin-top: 0.5rem; letter-spacing: -0.03em;">🎓 다수 기관 AI 실무 강의</h3>
        </div>
        <div style="text-align: right;">
          <div style="font-size: 2rem; font-weight: 900; color: #d97706; letter-spacing: -0.03em; line-height: 1;">
            <span data-count="500" data-suffix="명+">500명+</span>
          </div>
          <div style="font-size: 0.78rem; color: #94a3b8; font-weight: 500;">누적 수강생</div>
        </div>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem;">
        {lectures.map((l, i) => (
          <div
            class={`reveal reveal-delay-${i + 1}`}
            style={`padding: 1.25rem; background: ${l.bg}; border: 1px solid ${l.border}; border-radius: 1rem;`}
          >
            <span style={`font-size: 0.68rem; font-weight: 700; color: ${l.color}; text-transform: uppercase; letter-spacing: 0.08em;`}>{l.type}</span>
            <p style="font-size: 0.925rem; font-weight: 700; color: #0f172a; margin-top: 0.25rem;">{l.org}</p>
            <p style={`font-size: 0.8rem; color: ${l.color}; font-weight: 600; margin-top: 0.25rem;`}>{l.count}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    section#trust div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
  @media (max-width: 640px) {
    div[style*="grid-template-columns: repeat(auto-fit, minmax(200px"] {
      grid-template-columns: 1fr 1fr !important;
    }
  }
</style>
