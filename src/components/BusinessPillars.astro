---
---

<section id="pillars" style="padding: 8rem 1.5rem; background: #f8f9fc; position: relative; overflow: hidden;">
  <!-- Grid bg -->
  <div class="bg-grid-light" style="position: absolute; inset: 0; z-index: 0;"></div>

  <!-- Orbs -->
  <div class="orb" style="width: 500px; height: 500px; top: -5%; right: -8%; background: radial-gradient(circle, rgba(109,40,217,0.08) 0%, transparent 70%);"></div>
  <div class="orb" style="width: 400px; height: 400px; bottom: -5%; left: -5%; background: radial-gradient(circle, rgba(37,99,235,0.07) 0%, transparent 70%);"></div>

  <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
    <!-- Header -->
    <div class="reveal" style="text-align: center; margin-bottom: 4rem;">
      <span class="section-label" style="margin-bottom: 1.25rem; display: inline-flex;">3대 비즈니스 영역</span>
      <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; margin-top: 1.25rem; color: #0f172a;">
        하나의 그라운드, <span class="gradient-text">세 가지 강점</span>
      </h2>
      <p style="font-size: 1.05rem; color: #64748b; margin-top: 1rem; max-width: 480px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        AI SaaS, 공간 운영, 지식 콘텐츠가 하나의 생태계로 연결됩니다.
      </p>
    </div>

    <!-- Bento Grid -->
    <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem;">

      <!-- Large: AI SaaS (7 col) -->
      <article
        class="card card-hover reveal"
        style="
          grid-column: span 7;
          border-radius: 1.75rem;
          padding: 2.75rem;
          position: relative;
          overflow: hidden;
          background: white;
        "
      >
        <!-- Accent gradient top-left -->
        <div style="position: absolute; top: -60px; left: -60px; width: 240px; height: 240px; background: radial-gradient(circle, rgba(109,40,217,0.1) 0%, transparent 70%); pointer-events: none;"></div>

        <!-- Top accent line -->
        <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #4f46e5, #8b5cf6, #06b6d4); border-radius: 1.75rem 1.75rem 0 0;"></div>

        <div style="display: flex; align-items: flex-start; gap: 1.25rem; margin-bottom: 1.75rem;">
          <div style="width: 56px; height: 56px; background: linear-gradient(135deg, #4f46e5, #8b5cf6); border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(79,70,229,0.25); flex-shrink: 0;">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75">
              <path d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18"/>
            </svg>
          </div>
          <div>
            <span style="font-size: 0.72rem; font-weight: 700; color: #4f46e5; background: rgba(79,70,229,0.08); border: 1px solid rgba(79,70,229,0.15); padding: 0.2rem 0.75rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;">Core Product</span>
            <h3 style="font-size: 1.7rem; font-weight: 900; color: #0f172a; margin-top: 0.4rem; letter-spacing: -0.03em;">AI SaaS</h3>
            <p style="font-size: 0.875rem; color: #64748b; margin-top: 0.1rem;">무인 공간 CRM & 자동화 솔루션</p>
          </div>
        </div>

        <p style="font-size: 1rem; color: #475569; line-height: 1.75; margin-bottom: 1.75rem;">
          파티룸, 스터디카페 등 무인 공간 운영자를 위한 AI 기반 CRM. 예약 관리, 고객 응대, 매출 분석을 자동화합니다.
        </p>

        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;">
          {['AI 예약 자동화', '고객 CRM', '매출 분석 대시보드', '실시간 모니터링'].map(f => (
            <span style="font-size: 0.8rem; color: #4f46e5; background: rgba(79,70,229,0.06); border: 1px solid rgba(79,70,229,0.12); padding: 0.3rem 0.8rem; border-radius: 7px; font-weight: 500;">✦ {f}</span>
          ))}
        </div>

        <a href="#contact" style="display: inline-flex; align-items: center; gap: 0.5rem; color: #4f46e5; font-weight: 700; font-size: 0.9rem; text-decoration: none; transition: all 0.2s ease; border-bottom: 2px solid rgba(79,70,229,0.2); padding-bottom: 2px;" onmouseover="this.style.borderColor='#4f46e5'; this.style.gap='0.75rem'" onmouseout="this.style.borderColor='rgba(79,70,229,0.2)'; this.style.gap='0.5rem'">
          사전 신청하기 →
        </a>
      </article>

      <!-- Right col: Space + Knowledge (5 col) -->
      <div style="grid-column: span 5; display: flex; flex-direction: column; gap: 1.25rem;">

        <!-- Space Operations -->
        <article
          class="card card-hover reveal reveal-delay-1"
          style="border-radius: 1.5rem; padding: 2rem; flex: 1; position: relative; overflow: hidden;"
        >
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #10b981, #06b6d4); border-radius: 1.5rem 1.5rem 0 0;"></div>
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <div style="width: 46px; height: 46px; background: linear-gradient(135deg, #10b981, #059669); border-radius: 13px; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 18px rgba(16,185,129,0.22); flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75">
                <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div>
              <span style="font-size: 0.7rem; font-weight: 700; color: #059669; background: rgba(16,185,129,0.08); border: 1px solid rgba(16,185,129,0.18); padding: 0.15rem 0.65rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;">Lab</span>
              <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-top: 0.25rem; letter-spacing: -0.02em;">Space Operations</h3>
            </div>
          </div>
          <p style="font-size: 0.875rem; color: #475569; line-height: 1.65; margin-bottom: 1rem;">
            직접 운영하는 파티룸에서 AI 솔루션을 실전 테스트합니다. 현장 데이터로 제품의 신뢰성을 증명합니다.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {['실제 운영 데이터', '제품 실증 검증', 'ROI 측정'].map(f => (
              <span style="font-size: 0.77rem; color: #059669; background: rgba(16,185,129,0.06); border: 1px solid rgba(16,185,129,0.14); padding: 0.25rem 0.65rem; border-radius: 6px; font-weight: 500;">✦ {f}</span>
            ))}
          </div>
        </article>

        <!-- Knowledge & Insight -->
        <article
          class="card card-hover reveal reveal-delay-2"
          style="border-radius: 1.5rem; padding: 2rem; flex: 1; position: relative; overflow: hidden;"
        >
          <div style="position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #f59e0b, #ef4444); border-radius: 1.5rem 1.5rem 0 0;"></div>
          <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
            <div style="width: 46px; height: 46px; background: linear-gradient(135deg, #f59e0b, #f97316); border-radius: 13px; display: flex; align-items: center; justify-content: center; box-shadow: 0 6px 18px rgba(245,158,11,0.25); flex-shrink: 0;">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75">
                <path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/>
              </svg>
            </div>
            <div>
              <span style="font-size: 0.7rem; font-weight: 700; color: #d97706; background: rgba(245,158,11,0.08); border: 1px solid rgba(245,158,11,0.2); padding: 0.15rem 0.65rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;">Expertise</span>
              <h3 style="font-size: 1.15rem; font-weight: 800; color: #0f172a; margin-top: 0.25rem; letter-spacing: -0.02em;">Knowledge & Insight</h3>
            </div>
          </div>
          <p style="font-size: 0.875rem; color: #475569; line-height: 1.65; margin-bottom: 1rem;">
            유튜브 IT 리뷰 채널 운영과 함께 기업, 공공기관, KDT 과정 AI 실무 강의를 제공합니다.
          </p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {['기업 AI 강의', 'KDT 교육', 'IT 콘텐츠'].map(f => (
              <span style="font-size: 0.77rem; color: #d97706; background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.14); padding: 0.25rem 0.65rem; border-radius: 6px; font-weight: 500;">✦ {f}</span>
            ))}
          </div>
        </article>
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    article[style*="grid-column: span 7"] { grid-column: span 12 !important; }
    div[style*="grid-column: span 5"] { grid-column: span 12 !important; }
  }
</style>
