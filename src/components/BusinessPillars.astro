---
const features = [
  {
    icon: `<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>`,
    iconGradient: 'linear-gradient(135deg, #4f46e5, #8b5cf6)',
    iconShadow: '0 8px 24px rgba(79,70,229,0.28)',
    accent: '#4f46e5',
    accentBg: 'rgba(79,70,229,0.07)',
    accentBorder: 'rgba(79,70,229,0.14)',
    topBar: 'linear-gradient(90deg, #4f46e5, #8b5cf6, #06b6d4)',
    badge: 'AI 엔진',
    emoji: '🤖',
    title: 'RAG 기반 문의응답 AI 챗봇',
    subtitle: '24시간 고객 문의 자동 응대',
    desc: '운영자의 FAQ·가격표·예약 정책을 학습해 24시간 고객 문의에 자동 답변합니다. 카카오채널·인스타 DM·웹 위젯 멀티채널 지원으로 반복 문의의 85%를 자동 처리합니다.',
    tags: ['카카오채널', '인스타 DM', '웹 위젯', 'RAG 아키텍처'],
    stats: [
      { value: '85', suffix: '%+', label: '반복 문의 자동 처리' },
      { value: '24', suffix: 'h', label: '무중단 응대' },
    ],
    large: true,
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.82 19.79 19.79 0 01.1 1.2 2 2 0 012.11 0h3a2 2 0 012 1.72 12.8 12.8 0 00.7 2.81 2 2 0 01-.45 2.11L6.18 7.84a16 16 0 006 6l1.19-1.19a2 2 0 012.11-.45 12.8 12.8 0 002.81.7A2 2 0 0122 14.12v.8"/></svg>`,
    iconGradient: 'linear-gradient(135deg, #10b981, #059669)',
    iconShadow: '0 6px 18px rgba(16,185,129,0.25)',
    accent: '#059669',
    accentBg: 'rgba(5,150,105,0.07)',
    accentBorder: 'rgba(5,150,105,0.15)',
    topBar: 'linear-gradient(90deg, #10b981, #06b6d4)',
    badge: '자동화',
    emoji: '📱',
    title: '자동 예약 문자',
    subtitle: '노쇼 감소 & 알림톡 자동 발송',
    desc: '예약 생성·변경·D-1·당일·완료 이벤트별로 알림톡·SMS가 자동 발송됩니다. 수동 발송 0건, 노쇼 방지.',
    tags: ['카카오 알림톡', 'SMS/LMS', '네이버 예약 연동'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
    iconGradient: 'linear-gradient(135deg, #f59e0b, #f97316)',
    iconShadow: '0 6px 18px rgba(245,158,11,0.28)',
    accent: '#d97706',
    accentBg: 'rgba(217,119,6,0.07)',
    accentBorder: 'rgba(217,119,6,0.15)',
    topBar: 'linear-gradient(90deg, #f59e0b, #ef4444)',
    badge: 'CRM',
    emoji: '📅',
    title: '예약 관리 & 고객 관리',
    subtitle: '통합 CRM 대시보드',
    desc: '달력/리스트 뷰 예약 현황 조회, 고객별 예약 이력·재방문율 분석, 노쇼 방지 자동 알림, 블랙리스트 관리까지.',
    tags: ['달력 뷰', '고객 이력', '블랙리스트', '운영 리포트'],
  },
  {
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>`,
    iconGradient: 'linear-gradient(135deg, #0891b2, #4f46e5)',
    iconShadow: '0 6px 18px rgba(8,145,178,0.25)',
    accent: '#0891b2',
    accentBg: 'rgba(8,145,178,0.07)',
    accentBorder: 'rgba(8,145,178,0.15)',
    topBar: 'linear-gradient(90deg, #0891b2, #4f46e5)',
    badge: '정산',
    emoji: '💰',
    title: '매출 관리',
    subtitle: '결제 수단별 자동 집계',
    desc: '현금·카드·계좌이체·간편결제 수단별 매출 통합 조회, 미수금 자동 감지 및 요청 알림, 일/주/월 정산 리포트 자동 생성.',
    tags: ['카카오페이', '미수금 관리', '정산 리포트'],
  },
];
---

<section id="features" style="padding: 8rem 1.5rem; background: #f8f9fc; position: relative; overflow: hidden;">
  <!-- Grid bg -->
  <div class="bg-grid-light" style="position: absolute; inset: 0; z-index: 0;"></div>
  <div class="orb" style="width: 500px; height: 500px; top: -5%; right: -8%; background: radial-gradient(circle, rgba(109,40,217,0.08) 0%, transparent 70%);"></div>
  <div class="orb" style="width: 400px; height: 400px; bottom: -5%; left: -5%; background: radial-gradient(circle, rgba(37,99,235,0.07) 0%, transparent 70%);"></div>

  <div style="max-width: 1200px; margin: 0 auto; position: relative; z-index: 1;">
    <!-- Header -->
    <div class="reveal" style="text-align: center; margin-bottom: 4rem;">
      <span class="section-label" style="margin-bottom: 1.25rem; display: inline-flex;">스페이스데스크 핵심 기능</span>
      <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; letter-spacing: -0.04em; line-height: 1.15; margin-top: 1.25rem; color: #0f172a;">
        하나로 끝내는 <span class="gradient-text">무인 공간 자동화</span>
      </h2>
      <p style="font-size: 1.05rem; color: #64748b; margin-top: 1rem; max-width: 520px; margin-left: auto; margin-right: auto; line-height: 1.7;">
        문의 응대부터 예약·정산까지, 스페이스데스크 4대 기능이 운영자의 반복 업무를 완전 자동화합니다.
      </p>
    </div>

    <!-- Bento Grid -->
    <div style="display: grid; grid-template-columns: repeat(12, 1fr); gap: 1.25rem;">

      <!-- Large: AI 챗봇 (7 col) -->
      <article
        class="card card-hover reveal"
        style="
          grid-column: span 7;
          border-radius: 1.75rem;
          padding: 2.75rem;
          position: relative;
          overflow: hidden;
          background: white;
        "
      >
        <div style="position: absolute; top: -60px; left: -60px; width: 240px; height: 240px; background: radial-gradient(circle, rgba(109,40,217,0.1) 0%, transparent 70%); pointer-events: none;"></div>
        <div style={`position: absolute; top: 0; left: 0; right: 0; height: 3px; background: ${features[0].topBar}; border-radius: 1.75rem 1.75rem 0 0;`}></div>

        <div style="display: flex; align-items: flex-start; gap: 1.25rem; margin-bottom: 1.75rem;">
          <div style={`width: 56px; height: 56px; background: ${features[0].iconGradient}; border-radius: 16px; display: flex; align-items: center; justify-content: center; box-shadow: ${features[0].iconShadow}; flex-shrink: 0;`}>
            <Fragment set:html={features[0].icon} />
          </div>
          <div>
            <span style={`font-size: 0.72rem; font-weight: 700; color: ${features[0].accent}; background: ${features[0].accentBg}; border: 1px solid ${features[0].accentBorder}; padding: 0.2rem 0.75rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;`}>{features[0].badge}</span>
            <h3 style="font-size: 1.55rem; font-weight: 900; color: #0f172a; margin-top: 0.4rem; letter-spacing: -0.03em;">{features[0].emoji} {features[0].title}</h3>
            <p style="font-size: 0.875rem; color: #64748b; margin-top: 0.1rem;">{features[0].subtitle}</p>
          </div>
        </div>

        <p style="font-size: 1rem; color: #475569; line-height: 1.75; margin-bottom: 1.75rem;">{features[0].desc}</p>

        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2rem;">
          {features[0].tags.map(tag => (
            <span style={`font-size: 0.8rem; color: ${features[0].accent}; background: ${features[0].accentBg}; border: 1px solid ${features[0].accentBorder}; padding: 0.3rem 0.8rem; border-radius: 7px; font-weight: 500;`}>✦ {tag}</span>
          ))}
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; padding: 1.25rem; background: #f8f9fc; border-radius: 1rem;">
          {features[0].stats!.map(s => (
            <div style="text-align: center;">
              <div style={`font-size: 2rem; font-weight: 900; color: ${features[0].accent}; letter-spacing: -0.03em; line-height: 1;`}>
                <span data-count={s.value} data-suffix={s.suffix}>{s.value}{s.suffix}</span>
              </div>
              <div style="font-size: 0.78rem; color: #94a3b8; margin-top: 0.35rem; font-weight: 500;">{s.label}</div>
            </div>
          ))}
        </div>
      </article>

      <!-- Right col: 3 small cards (5 col) -->
      <div style="grid-column: span 5; display: flex; flex-direction: column; gap: 1.25rem;">
        {features.slice(1).map((f, i) => (
          <article
            class={`card card-hover reveal reveal-delay-${i + 1}`}
            style="border-radius: 1.5rem; padding: 2rem; flex: 1; position: relative; overflow: hidden; background: white;"
          >
            <div style={`position: absolute; top: 0; left: 0; right: 0; height: 3px; background: ${f.topBar}; border-radius: 1.5rem 1.5rem 0 0;`}></div>
            <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
              <div style={`width: 46px; height: 46px; background: ${f.iconGradient}; border-radius: 13px; display: flex; align-items: center; justify-content: center; box-shadow: ${f.iconShadow}; flex-shrink: 0;`}>
                <Fragment set:html={f.icon} />
              </div>
              <div>
                <span style={`font-size: 0.7rem; font-weight: 700; color: ${f.accent}; background: ${f.accentBg}; border: 1px solid ${f.accentBorder}; padding: 0.15rem 0.65rem; border-radius: 9999px; letter-spacing: 0.08em; text-transform: uppercase;`}>{f.badge}</span>
                <h3 style="font-size: 1.05rem; font-weight: 800; color: #0f172a; margin-top: 0.25rem; letter-spacing: -0.02em;">{f.emoji} {f.title}</h3>
              </div>
            </div>
            <p style="font-size: 0.875rem; color: #475569; line-height: 1.65; margin-bottom: 1rem;">{f.desc}</p>
            <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
              {f.tags.map(tag => (
                <span style={`font-size: 0.77rem; color: ${f.accent}; background: ${f.accentBg}; border: 1px solid ${f.accentBorder}; padding: 0.25rem 0.65rem; border-radius: 6px; font-weight: 500;`}>✦ {tag}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @media (max-width: 900px) {
    article[style*="grid-column: span 7"] { grid-column: span 12 !important; }
    div[style*="grid-column: span 5"] { grid-column: span 12 !important; }
  }
</style>
